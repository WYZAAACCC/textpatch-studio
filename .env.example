# TextPatch Studio 环境变量配置

# ----- 安全 -----
# 监听地址 (默认 127.0.0.1，公网部署改为 0.0.0.0 前请先开启认证)
TEXTPATCH_HOST=127.0.0.1
# TEXTPATCH_PORT=8000

# API Token 认证 (公网部署时建议开启)
# TEXTPATCH_REQUIRE_AUTH=false
# TEXTPATCH_API_TOKEN=your-secret-token-here
# TEXTPATCH_ALLOWED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000

# ----- LLM -----
# DeepSeek API Key (必需: 用于LLM文字校正)
DEEPSEEK_API_KEY=sk-your-api-key-here

# DeepSeek API Base (可选，默认 https://api.deepseek.com)
# DEEPSEEK_API_BASE=https://api.deepseek.com

# DeepSeek 模型 (可选，默认 deepseek-v4-flash)
# DEEPSEEK_MODEL=deepseek-v4-flash

# 指定LLM模型 (可选，覆盖默认)
# TEXTPATCH_LLM_MODEL=deepseek-v4-flash

# 远程 LLM 开关 (默认 false，显式设为 true 才会调用外部 LLM)
# TEXTPATCH_REMOTE_LLM_ENABLED=false

# ----- OCR -----
# PaddleOCR API 地址 (可选，不配置则使用本地 RapidOCR)
# TEXTPATCH_OCR_API_URL=

# PaddleOCR API Token (可选)
# TEXTPATCH_OCR_TOKEN=

# 远程 OCR 开关 (默认 false)
# TEXTPATCH_REMOTE_OCR_ENABLED=false

# ----- 存储 -----
# 数据存储目录 (可选，默认 data/projects)
# TEXTPATCH_DATA_DIR=data/projects

# ----- 调试 -----
# TEXTPATCH_DEBUG=false
