# TextPatch Studio 环境变量配置

# DeepSeek API Key (必需: 用于LLM文字校正)
DEEPSEEK_API_KEY=sk-your-api-key-here

# DeepSeek API Base (可选，默认 https://api.deepseek.com)
# DEEPSEEK_API_BASE=https://api.deepseek.com

# DeepSeek 模型 (可选，默认 deepseek-v4-flash)
# DEEPSEEK_MODEL=deepseek-v4-flash

# 指定LLM模型 (可选，覆盖默认)
# TEXTPATCH_LLM_MODEL=deepseek-v4-flash

# PaddleOCR API 地址 (可选，不配置则使用本地 RapidOCR)
# TEXTPATCH_OCR_API_URL=

# PaddleOCR API Token (可选)
# TEXTPATCH_OCR_TOKEN=

# 数据存储目录 (可选，默认 data/projects)
# TEXTPATCH_DATA_DIR=data/projects

# 调试模式 (可选)
# TEXTPATCH_DEBUG=false
